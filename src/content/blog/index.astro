---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 自动抓取所有英文文章，并按照时间倒序排列（最新的在最上面）
const allPosts = await getCollection('blog', ({ id }) => id.startsWith('en/'));
const sortedPosts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout title="Insights & Updates | Grandevity" lang="en">
  <main class="blog-container">
    <header class="blog-header">
      <h1>Grandevity <span class="text-gradient">Insights</span></h1>
      <p>Thoughts on business architecture, AI solutions, game development, and the humanities.</p>
    </header>

    <div class="articles-grid">
      {sortedPosts.map((post) => (
        <a href={`/blog/${post.slug.replace('en/', '')}`} class="article-card">
          <span class="category-badge">{post.data.category}</span>
          <h2>{post.data.title}</h2>
          <p class="description">{post.data.description}</p>
          <div class="meta">
            <time>{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
          </div>
        </a>
      ))}
    </div>
  </main>
</Layout>

<style>
  .blog-container { padding: 4rem 5%; max-width: 1200px; margin: 0 auto; min-height: 70vh; }
  .blog-header { text-align: center; margin-bottom: 4rem; }
  .blog-header h1 { font-size: 3.5rem; margin-bottom: 1rem; color: #f8fafc; }
  .text-gradient { background-image: linear-gradient(45deg, #38bdf8, #818cf8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-size: 400%; background-position: 0%; }
  .blog-header p { color: #94a3b8; font-size: 1.2rem; }
  
  .articles-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 2rem; }
  .article-card { 
    display: flex; flex-direction: column; 
    background: var(--card-bg, #1e293b); 
    padding: 2rem; border-radius: 12px; 
    border: 1px solid rgba(255,255,255,0.05); 
    text-decoration: none; color: inherit; 
    transition: transform 0.2s, border-color 0.2s; 
  }
  .article-card:hover { transform: translateY(-5px); border-color: rgba(56, 189, 248, 0.5); }
  .category-badge { align-self: flex-start; background: rgba(56, 189, 248, 0.1); color: #38bdf8; padding: 0.25rem 0.75rem; border-radius: 999px; font-size: 0.8rem; font-weight: 600; margin-bottom: 1rem; }
  .article-card h2 { font-size: 1.4rem; margin: 0 0 1rem 0; color: #f8fafc; line-height: 1.4; }
  .description { color: #94a3b8; margin: 0 0 1.5rem 0; line-height: 1.6; flex-grow: 1; }
  .meta { font-size: 0.85rem; color: #64748b; margin-top: auto; }
</style>
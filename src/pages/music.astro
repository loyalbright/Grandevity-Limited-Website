---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { isReleasePublished } from '../utils/publishing';

const releases = (await getCollection('releases'))
  .filter(({ data }) => isReleasePublished(data))
  .sort((a, b) => b.data.releaseDate.valueOf() - a.data.releaseDate.valueOf());
---

<Layout title="Original Music | Grandevity" lang="en">
  <main class="page-container">
    <header class="page-header">
      <h1>A Contemporary <span class="text-gradient">Renaissance</span></h1>
      <p class="subtitle">Bridging the gap between historical masterpieces and modern aesthetics. We focus on composing modern pop arrangements (Mandopop, Indie, Chillhop) for ancient traditional Chinese poetry. Join us for a musical journey perfect for driving, relaxing, and healing the modern soul.</p>
    </header>

    <div class="page-content">
      <section class="video-section">
        <h2>Latest Releases</h2>
        
        <div class="video-grid">
          {releases.map(({ data }) => (
            <div class="video-container">
              <iframe
                width="100%"
                height="100%"
                src={`https://www.youtube.com/embed/${data.youtubeId}?rel=0`}
                title={data.title.en}
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
          ))}
        </div>

        <div class="channel-link">
          <a href="https://www.youtube.com/channel/UC8Uch86j4-V7pm7RorRI3GQ" target="_blank" rel="noopener noreferrer">
            Explore more on YouTube ➔
          </a>
        </div>
      </section>

      <section class="copyright-section">
        <h2>Business & Copyright</h2>
        <div class="details-box">
          <p>All original music, arrangements, and visual contents are operated and copyrighted by <strong>Grandevity Limited</strong>. We welcome non-exclusive BGM licensing for indie games, films, vlogs, and commercials.</p>
          <p><strong>Business Inquiries:</strong> <a href="mailto:info@grandevity.co.nz">info@grandevity.co.nz</a></p>
        </div>
      </section>
    </div>
  </main>
</Layout>

<style>
  .page-container { 
    padding: 4rem 5%; 
    max-width: 1200px; /* 稍微加宽以容纳更好的网格 */
    margin: 0 auto; 
    min-height: 70vh; 
    color: #cbd5e1;
  }
  .page-header { 
    text-align: center; 
    margin-bottom: 4rem; 
  }
  .page-header h1 { 
    font-size: 3.5rem; 
    margin-bottom: 1rem; 
    color: #f8fafc; 
  }
  .text-gradient { 
    background-image: linear-gradient(45deg, #38bdf8, #818cf8); 
    -webkit-background-clip: text; 
    -webkit-text-fill-color: transparent; 
  }
  .subtitle { 
    color: #94a3b8; 
    font-size: 1.2rem; 
    line-height: 1.7;
    max-width: 800px;
    margin: 0 auto;
  }
  
  .page-content h2 { 
    color: #f8fafc; 
    font-size: 2rem; 
    margin-bottom: 2rem; 
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding-bottom: 0.5rem;
  }
  
  .video-section {
    margin-bottom: 4rem;
  }
  
  /* 全新统一的网格布局 */
  .video-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(400px, 1fr)); /* 保证视频有足够的观看宽度 */
    gap: 2.5rem;
  }

  .video-container {
    border-radius: 12px; 
    overflow: hidden; 
    aspect-ratio: 16/9; 
    background: #000;
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: transform 0.3s ease, border-color 0.3s ease;
  }
  
  .video-container:hover {
    transform: translateY(-5px);
    border-color: rgba(56, 189, 248, 0.4);
  }

  .channel-link {
    text-align: right; 
    margin-top: 2rem;
  }
  .channel-link a {
    color: #38bdf8; 
    text-decoration: none; 
    font-weight: 500; 
    font-size: 1.1rem;
    transition: color 0.2s;
  }
  .channel-link a:hover {
    color: #818cf8;
    text-decoration: underline;
  }

  .details-box {
    background: #0f172a;
    padding: 2rem;
    border-radius: 8px;
    border-left: 4px solid #38bdf8;
  }
  .details-box p {
    margin-bottom: 1rem;
    font-size: 1.1rem;
    line-height: 1.8;
  }
  .details-box p:last-child {
    margin-bottom: 0;
  }
  .details-box strong {
    color: #f8fafc;
  }
  .details-box a {
    color: #38bdf8;
    text-decoration: none;
  }
  .details-box a:hover {
    text-decoration: underline;
  }
  
  /* 响应式调整：在小屏幕上让视频填满宽度 */
  @media (max-width: 768px) {
    .video-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

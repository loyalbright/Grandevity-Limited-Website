---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Original Music & OSTs - Grandevity Limited" lang="en">
  <main style="max-width: 800px; margin: 0 auto; padding: 2rem 1rem; min-height: 70vh;">
    <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem; color: #1e293b;">Original Music</h1>
    <p style="color: #64748b; margin-bottom: 3rem; font-size: 1.1rem;">
      Explore the original soundtracks and immersive audio experiences crafted for our games.
    </p>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
      
      <div style="border: 1px solid #e2e8f0; border-radius: 12px; padding: 1.5rem; background: #f8fafc;">
        <h2 style="margin-top: 0; color: #0f172a;">Kiwi Defenders OST</h2>
        <p style="color: #475569; font-size: 0.95rem;">The complete original soundtrack featuring dynamic battle anthems and ambient exploration tracks.</p>
        <div style="margin-top: 1rem; padding: 1rem; background: #e2e8f0; border-radius: 8px; text-align: center; color: #64748b;">
          [ Audio Player / Embed Will Go Here ]
        </div>
      </div>

      <div style="border: 1px solid #e2e8f0; border-radius: 12px; padding: 1.5rem; background: #f8fafc;">
        <h2 style="margin-top: 0; color: #0f172a;">Project: Pebble (WIP)</h2>
        <p style="color: #475569; font-size: 0.95rem;">Early audio prototypes and atmospheric sketches for our upcoming interactive experience.</p>
        <div style="margin-top: 1rem; padding: 1rem; background: #e2e8f0; border-radius: 8px; text-align: center; color: #64748b;">
          [ Audio Player / Embed Will Go Here ]
        </div>
      </div>

    </div>
  </main>
</Layout>
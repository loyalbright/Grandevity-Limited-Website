---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { isPublished, isReleasePublished } from '../../utils/publishing';

export async function getStaticPaths() {
  const releases = await getCollection('releases');
  const blogEntries = await getCollection('blog', ({ id, data }) => {
    return id.startsWith('en/music/') && isPublished(data.date);
  });

  return releases
    .filter(({ data }) => isReleasePublished(data))
    .map((release) => {
      const article = blogEntries.find((entry) => entry.id === `en/music/${release.data.articleSlug}`);

      return {
        params: { slug: release.id },
        props: { release, article },
      };
    });
}

const { release, article } = Astro.props;
const { data } = release;
const releaseDate = data.releaseDate.toLocaleDateString('en-NZ', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const isoReleaseDate = data.releaseDate.toISOString().slice(0, 10);
const pageTitle = `${data.title.en} | Original Music`;
const description = `${data.title.en} by Grandevity Studio. Watch the official music video and find streaming links.`;
const youtubeUrl = `https://www.youtube.com/watch?v=${data.youtubeId}`;
const embedUrl = `https://www.youtube.com/embed/${data.youtubeId}?rel=0`;
const platformLinks: { label: string; href: string }[] = [
  ...(data.hyperfollow ? [{ label: 'HyperFollow', href: data.hyperfollow }] : []),
  ...(data.platforms?.spotify ? [{ label: 'Spotify', href: data.platforms.spotify }] : []),
  ...(data.platforms?.appleMusic ? [{ label: 'Apple Music', href: data.platforms.appleMusic }] : []),
  ...(data.platforms?.youtubeMusic ? [{ label: 'YouTube Music', href: data.platforms.youtubeMusic }] : []),
  ...(data.platforms?.tidal ? [{ label: 'TIDAL', href: data.platforms.tidal }] : []),
  { label: 'YouTube', href: youtubeUrl },
];
const schema = {
  '@context': 'https://schema.org',
  '@type': 'MusicRecording',
  name: data.title.en,
  url: new URL(Astro.url.pathname, Astro.site).toString(),
  datePublished: isoReleaseDate,
  inLanguage: 'en',
  byArtist: {
    '@type': 'MusicGroup',
    name: 'Grandevity Studio',
  },
  video: {
    '@type': 'VideoObject',
    name: `${data.title.en} Official Music Video`,
    embedUrl: `https://www.youtube.com/embed/${data.youtubeId}`,
    uploadDate: isoReleaseDate,
  },
};
---

<Layout title={pageTitle} lang="en" description={description} schema={schema}>
  <main class="release-page">
    <a class="back-link" href="/music/">← All music</a>

    <header class="release-header">
      <p class="eyebrow">Grandevity Studio Original Music</p>
      <h1>{data.title.en}</h1>
      <p class="subtitle">
        A modern Mandopop release from Grandevity Studio{data.classicalSource && <> inspired by {data.classicalSource.en}</>}.
      </p>
    </header>

    <section class="video-panel" aria-label={`${data.title.en} official music video`}>
      <iframe
        width="100%"
        height="100%"
        src={embedUrl}
        title={`${data.title.en} Official Music Video`}
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
    </section>

    <section class="release-grid">
      <div class="details-box">
        <h2>Release Details</h2>
        <dl>
          <div>
            <dt>Release date</dt>
            <dd>{releaseDate}</dd>
          </div>
          {data.classicalSource && (
            <div>
              <dt>Classical source</dt>
              <dd>{data.classicalSource.en}</dd>
            </div>
          )}
          <div>
            <dt>Project</dt>
            <dd>Grandevity Music</dd>
          </div>
        </dl>
      </div>

      <div class="details-box">
        <h2>Listen & Read</h2>
        <div class="link-list">
          {platformLinks.map((link) => (
            <a href={link.href} target="_blank" rel="noopener noreferrer">{link.label}</a>
          ))}
          {article && <a href={`/blog/music/${data.articleSlug}/`}>Read the article</a>}
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .release-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 4rem 5%;
    color: #cbd5e1;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    color: #38bdf8;
    text-decoration: none;
    font-weight: 600;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .release-header {
    max-width: 820px;
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: #38bdf8;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0 0 1rem;
    color: #f8fafc;
    font-size: clamp(2.25rem, 6vw, 4rem);
    line-height: 1.05;
  }

  .subtitle {
    margin: 0;
    color: #94a3b8;
    font-size: 1.15rem;
    line-height: 1.7;
  }

  .video-panel {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 12px;
    background: #000;
    border: 1px solid rgba(255, 255, 255, 0.07);
    box-shadow: 0 18px 45px -20px rgba(0, 0, 0, 0.9);
  }

  .release-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.72fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }

  .details-box {
    background: #0f172a;
    padding: 1.5rem;
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.07);
  }

  .details-box h2 {
    margin: 0 0 1rem;
    color: #f8fafc;
    font-size: 1.25rem;
  }

  dl {
    margin: 0;
  }

  dl div {
    padding: 0.85rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  dt {
    color: #94a3b8;
    font-size: 0.86rem;
    margin-bottom: 0.25rem;
  }

  dd {
    margin: 0;
    color: #f8fafc;
    line-height: 1.55;
  }

  .link-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .link-list a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 1rem;
    color: #0f172a;
    background: #38bdf8;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 700;
  }

  .link-list a:hover {
    background: #818cf8;
  }

  @media (max-width: 768px) {
    .release-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

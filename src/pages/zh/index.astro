---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 抓取中文博客，并过滤掉未来发布的文章
const allPosts = await getCollection('blog', ({ id }) => id.startsWith('zh/'));
const today = new Date();
const visiblePosts = allPosts.filter(post => new Date(post.data.date) <= today);

// 提取音乐板块文章 (路径包含 'music/')
const musicPosts = visiblePosts
  .filter(post => post.id.includes('music/'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);

// 提取洞见板块文章 (排除音乐)
const latestInsights = visiblePosts
  .filter(post => !post.id.includes('music/'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);
---

<Layout title="Grandevity | 互动工作室与数字解决方案" lang="zh">
  <main>
    <header class="hero">
      <h1>构建 <span class="text-gradient">数字世界</span></h1>
      <p>Grandevity 是一家多领域混合型工作室，致力于打造原创互动体验，并为现代企业提供顶级的数字架构、财务合规与战略咨询服务。</p>
    </header>

    <section id="music" class="section-container">
      <h2>古典新编音乐</h2>
      <p class="section-subtitle">用现代视听语言，重构跨越千年的古典诗词与精神坐标。</p>
      
      <div class="card-grid">
        {musicPosts.length === 0 ? (
          <div class="card" style="grid-column: 1 / -1; text-align: center;">
            <div class="card-content">
              <p>全新视听企划正在制作中，敬请期待。</p>
            </div>
          </div>
        ) : (
          musicPosts.map((post) => (
            <div class="card">
              <div class="card-content">
                <h3>{post.data.title}</h3>
                <span class="badge" style="background: rgba(168, 85, 247, 0.1); color: #c084fc;">🎵 最新单曲释出</span>
                <p>{post.data.description}</p>
                <a href={`/zh/blog/${post.id.replace('zh/', '')}`} class="cta-button">了解企划详情 ➔</a>
              </div>
            </div>
          ))
        )}
      </div>

      <div style="text-align: center; margin-top: 3rem;">
        <a href="/zh/music" style="color: #94a3b8; text-decoration: none; border-bottom: 1px solid #475569; padding-bottom: 2px; transition: color 0.2s;">
          进入视听主页探索所有 MV ➔
        </a>
      </div>
    </section>

    <section id="games" class="section-container">
      <h2>原创游戏</h2>
      
      <div class="card-grid">
        <div class="card game-card">
          <a href="/play/kiwi-defenders/" style="text-decoration: none;">
            <div class="game-image-placeholder" style="background-image: url('/images/games/kiwi-defenders/landscape_cover_campaign_map.webp'); background-size: cover; background-position: center;">
              <span style="background: rgba(0,0,0,0.7); padding: 0.5rem 1rem; border-radius: 4px; color: #38bdf8; font-weight: bold; font-size: 1.2rem; backdrop-filter: blur(4px);">▶ 点击试玩 Demo</span>
            </div>
          </a>
          <div class="card-content">
            <h3>Kiwi Defenders</h3>
            <span class="badge" style="background: rgba(34, 197, 94, 0.1); color: #22c55e;">试玩版上线</span>
            <p>一款极具策略性的 HTML5 塔防游戏。在独特的几维鸟主题战役地图上指挥你的防线。直接在浏览器中体验纯净的无 SDK 独立版本。</p>
            <a href="/play/kiwi-defenders/" class="cta-button">立即游玩 ➔</a>
          </div>
        </div>

        <div class="card game-card">
          <div class="game-image-placeholder" style="background: #0f172a; background-size: cover; background-position: center;">
            <span style="color: #475569; font-weight: 800; font-size: 1.5rem; letter-spacing: 4px;">[ 机密档案 ]</span>
          </div>
          <div class="card-content">
            <h3>代号：Pebble <span style="font-size: 0.8rem; font-weight: normal; color: #94a3b8;">(开发代号)</span></h3>
            <span class="badge" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b;">研发中</span>
            <p>我们的下一款原创作品目前正处于早期原型设计和核心工程阶段。探索全新的互动机制，更多细节即将公布。</p>
          </div>
        </div>
      </div>
    </section>

    <section id="insights" class="section-container">
      <h2>最新洞见</h2>
      <p class="section-subtitle">深入探讨历史、系统设计与数字架构。</p>
      
      <div class="card-grid">
        {latestInsights.map((post) => (
          <div class="card">
            <div class="card-content">
              <h3>{post.data.title}</h3>
              <span class="badge" style="background: rgba(56, 189, 248, 0.1); color: #38bdf8;">{post.data.category || '洞察'}</span>
              <p>{post.data.description}</p>
              <a href={`/zh/blog/${post.id.replace('zh/', '')}`} class="cta-button">阅读文章 ➔</a>
            </div>
          </div>
        ))}
      </div>

      <div style="text-align: center; margin-top: 3rem;">
        <a href="/zh/blog" style="color: #94a3b8; text-decoration: none; border-bottom: 1px solid #475569; padding-bottom: 2px; transition: color 0.2s;">
          查看所有洞见 ➔
        </a>
      </div>
    </section>

    <section id="services" class="section-container">
      <h2>工作室服务</h2>
      <p class="section-subtitle">通过高水平的 B2B 企业合作，为我们的创新引擎提供动力。</p>
      
      <div class="card-grid">
        <div class="card">
          <div class="card-content">
            <h3>数字与网络服务</h3>
            <p>开发、维护和托管高性能的数字店面、网络工具与内容平台，确保架构的可扩展性。</p>
          </div>
        </div>
        <div class="card">
          <div class="card-content">
            <h3>商业咨询</h3>
            <p>为独立企业和初创公司提供战略性运营指导与流程优化咨询，提升运营效率。</p>
          </div>
        </div>
        <div class="card">
          <div class="card-content">
            <h3>财务与记账</h3>
            <p>编制财务记录和总账对账，确保绝对的精确度与合规性，为您的业务增长最大化资金跑道。</p>
          </div>
        </div>
        <div class="card">
          <div class="card-content">
            <h3>系统与 ERP 架构</h3>
            <p>定制 ERP 解决方案设计与实施，跨越财务数据与企业运营技术之间的鸿沟。</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  main { padding: 0 5%; max-width: 1200px; margin: 0 auto; }
  .hero { text-align: center; padding: 6rem 0; }
  h1 { font-size: 4rem; font-weight: 800; margin-bottom: 1rem; line-height: 1.1; }
  .text-gradient { background-image: linear-gradient(45deg, #38bdf8, #818cf8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-size: 400%; background-position: 0%; }
  .hero p { font-size: 1.2rem; color: #94a3b8; max-width: 600px; margin: 0 auto; line-height: 1.6; }
  
  .section-container { padding: 4rem 0; text-align: center; }
  h2 { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .section-subtitle { color: #94a3b8; margin-bottom: 3rem; }
  
  .card-grid { 
    display: grid; 
    grid-template-columns: repeat(auto-fit, minmax(450px, 1fr)); 
    gap: 2rem; 
    text-align: left; 
  }
  
  .card-grid.single { grid-template-columns: 1fr; max-width: 800px; margin: 0 auto; }
  
  .card { background: var(--card-bg, #1e293b); border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); overflow: hidden; transition: transform 0.2s, border-color 0.2s; }
  .card:hover { transform: translateY(-5px); border-color: rgba(56, 189, 248, 0.5); }
  .card-content { padding: 2rem; display: flex; flex-direction: column; height: 100%; }
  .card h3 { margin: 0 0 1rem 0; font-size: 1.5rem; color: #f8fafc; }
  .card p { color: #94a3b8; line-height: 1.5; margin: 0; flex-grow: 1; }
  .game-image-placeholder { width: 100%; aspect-ratio: 16 / 9; background: #0f172a; display: flex; align-items: center; justify-content: center; color: #475569; border-bottom: 1px solid rgba(255,255,255,0.05); }
  
  /* 确保紫色的徽章也靠左对齐 */
  .badge { align-self: flex-start; display: inline-block; background: rgba(56, 189, 248, 0.1); color: #38bdf8; padding: 0.25rem 0.75rem; border-radius: 999px; font-size: 0.8rem; font-weight: 600; margin-bottom: 1rem; }

  @media (max-width: 768px) {
    .card-grid { grid-template-columns: 1fr; }
  }

  .cta-button { 
    display: inline-block; 
    margin-top: 1.5rem; 
    padding: 0.5rem 1.5rem; 
    background: rgba(56, 189, 248, 0.1); 
    color: #38bdf8; 
    text-decoration: none; 
    border-radius: 999px; 
    font-weight: bold; 
    transition: all 0.2s ease;
    border: 1px solid #38bdf8;
    align-self: flex-start;
  }
  .cta-button:hover { 
    background: #38bdf8; 
    color: #0f172a; 
  }
</style>
---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { isPublished } from '../utils/publishing';

// 抓取英文博客，并过滤掉未来发布的文章
const allPosts = await getCollection('blog', ({ id }) => id.startsWith('en/'));
const visiblePosts = allPosts.filter(post => isPublished(post.data.date));

// 提取音乐板块文章 (路径包含 'music/')
const musicPosts = visiblePosts
  .filter(post => post.id.includes('music/'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);

// 提取洞见板块文章 (排除音乐)
const latestInsights = visiblePosts
  .filter(post => !post.id.includes('music/'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);
---

<Layout title="Grandevity | Interactive Studio & Digital Solutions" lang="en">
  <main>
    <header class="hero">
      <h1>Engineering <span class="text-gradient">Digital Worlds</span></h1>
      <p>Grandevity is a multi-disciplinary studio building original interactive experiences and providing elite digital, financial, and strategic consulting for modern businesses.</p>
    </header>

    <section id="music" class="section-container">
      <h2>Original Music</h2>
      <p class="section-subtitle">Modern pop arrangements for ancient traditional poetry. A contemporary renaissance.</p>
      
      <div class="card-grid">
        {musicPosts.length === 0 ? (
          <div class="card" style="grid-column: 1 / -1; text-align: center;">
            <div class="card-content">
              <p>New musical projects are currently in production. Stay tuned.</p>
            </div>
          </div>
        ) : (
          musicPosts.map((post) => (
            <a href={`/blog/${post.id.replace('en/', '')}`} class="card" style="text-decoration: none; color: inherit; display: block;">
              <div class="card-content">
                <h3>{post.data.title}</h3>
                <span class="badge" style="background: rgba(168, 85, 247, 0.1); color: #c084fc;">🎵 Music Release</span>
                <p>{post.data.description}</p>
                <div class="cta-button">View Project ➔</div>
              </div>
            </a>
          ))
        )}
      </div>

      <div style="text-align: center; margin-top: 3rem;">
        <a href="/music" style="color: #94a3b8; text-decoration: none; border-bottom: 1px solid #475569; padding-bottom: 2px; transition: color 0.2s;">
          Explore the Music Channel ➔
        </a>
      </div>
    </section>

    <section id="games" class="section-container">
      <h2>Original Games</h2>
      <div class="card-grid">
        <div class="card game-card">
          <a href="/play/kiwi-defenders/" style="text-decoration: none; display: block;">
            <div class="game-image-placeholder" style="background-image: url('/images/games/kiwi-defenders/landscape_cover_campaign_map.webp'); background-size: cover; background-position: center;">
              <span style="background: rgba(0,0,0,0.7); padding: 0.5rem 1rem; border-radius: 4px; color: #38bdf8; font-weight: bold; font-size: 1.2rem; backdrop-filter: blur(4px);">▶ Click to Play Demo</span>
            </div>
          </a>
          <div class="card-content">
            <h3>Kiwi Defenders</h3>
            <span class="badge" style="background: rgba(34, 197, 94, 0.1); color: #22c55e;">Playable Demo</span>
            <p>A strategic HTML5 tower defense experience. Command your defenses across a unique Kiwi-themed campaign map. Play the pure, SDK-free version directly in your browser.</p>
            <a href="/play/kiwi-defenders/" class="cta-button" style="display: inline-block;">Play Now ➔</a>
          </div>
        </div>

        <div class="card game-card">
          <div class="game-image-placeholder" style="background: #0f172a; background-size: cover; background-position: center;">
            <span style="color: #475569; font-weight: 800; font-size: 1.5rem; letter-spacing: 4px;">[ CLASSIFIED ]</span>
          </div>
          <div class="card-content">
            <h3>Project: Pebble <span style="font-size: 0.8rem; font-weight: normal; color: #94a3b8;">(Working Title)</span></h3>
            <span class="badge" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b;">In Development</span>
            <p>Our next original title is currently in the early prototyping and core engineering phase. Exploring fresh interactive mechanics. More details will be revealed soon.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="insights" class="section-container">
      <h2>Latest Insights</h2>
      <p class="section-subtitle">Deep dives into history, systems, and digital architecture.</p>
      
      <div class="card-grid">
        {latestInsights.map((post) => (
          <a href={`/blog/${post.id.replace('en/', '')}`} class="card" style="text-decoration: none; color: inherit; display: block;">
            <div class="card-content">
              <h3>{post.data.title}</h3>
              <span class="badge" style="background: rgba(56, 189, 248, 0.1); color: #38bdf8;">{post.data.category || 'Insight'}</span>
              <p>{post.data.description}</p>
              <div class="cta-button">Read Article ➔</div>
            </div>
          </a>
        ))}
      </div>

      <div style="text-align: center; margin-top: 3rem;">
        <a href="/blog" style="color: #94a3b8; text-decoration: none; border-bottom: 1px solid #475569; padding-bottom: 2px; transition: color 0.2s;">
          View all insights ➔
        </a>
      </div>
    </section>

    <section id="services" class="section-container">
      <h2>Studio Services</h2>
      <p class="section-subtitle">Powering our creative engine through high-caliber B2B enterprise partnerships.</p>
      
      <div class="card-grid">
        <div class="card">
          <div class="card-content">
            <h3>Digital & Web Services</h3>
            <p>Development, maintenance, and hosting of high-performance digital storefronts, web tools, and content platforms with scalable architecture.</p>
          </div>
        </div>
        <div class="card">
          <div class="card-content">
            <h3>Business Consulting</h3>
            <p>Strategic operational guidance and process optimization consulting for independent businesses and startups looking to scale efficiently.</p>
          </div>
        </div>
        <div class="card">
          <div class="card-content">
            <h3>Financial & Bookkeeping</h3>
            <p>Preparation of financial records and ledger reconciliation, ensuring absolute precision and compliance to maximize runway for your business.</p>
          </div>
        </div>
        <div class="card">
          <div class="card-content">
            <h3>Systems & ERP Architecture</h3>
            <p>Custom ERP solution design and implementation, bridging the gap between financial data and enterprise operational tech.</p>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  main { padding: 0 5%; max-width: 1200px; margin: 0 auto; }
  .hero { text-align: center; padding: 6rem 0; }
  h1 { font-size: 4rem; font-weight: 800; margin-bottom: 1rem; line-height: 1.1; }
  .text-gradient { background-image: linear-gradient(45deg, #38bdf8, #818cf8); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-size: 400%; background-position: 0%; }
  .hero p { font-size: 1.2rem; color: #94a3b8; max-width: 600px; margin: 0 auto; line-height: 1.6; }
  
  .section-container { padding: 4rem 0; text-align: center; }
  h2 { font-size: 2.5rem; margin-bottom: 0.5rem; }
  .section-subtitle { color: #94a3b8; margin-bottom: 3rem; }
  
  .card-grid { 
    display: grid; 
    grid-template-columns: repeat(auto-fit, minmax(450px, 1fr)); 
    gap: 2rem; 
    text-align: left; 
  }
  
  .card-grid.single { grid-template-columns: 1fr; max-width: 800px; margin: 0 auto; }
  
  .card { background: var(--card-bg, #1e293b); border-radius: 12px; border: 1px solid rgba(255,255,255,0.05); overflow: hidden; transition: transform 0.2s, border-color 0.2s; display: block; }
  .card:hover { transform: translateY(-5px); border-color: rgba(56, 189, 248, 0.5); }
  .card-content { padding: 2rem; display: flex; flex-direction: column; height: 100%; }
  .card h3 { margin: 0 0 1rem 0; font-size: 1.5rem; color: #f8fafc; }
  .card p { color: #94a3b8; line-height: 1.5; margin: 0; flex-grow: 1; }
  .game-image-placeholder { width: 100%; aspect-ratio: 16 / 9; background: #0f172a; display: flex; align-items: center; justify-content: center; color: #475569; border-bottom: 1px solid rgba(255,255,255,0.05); }
  
  .badge { align-self: flex-start; display: inline-block; background: rgba(56, 189, 248, 0.1); color: #38bdf8; padding: 0.25rem 0.75rem; border-radius: 999px; font-size: 0.8rem; font-weight: 600; margin-bottom: 1rem; }

  @media (max-width: 768px) {
    .card-grid { grid-template-columns: 1fr; }
  }

  .cta-button { 
    display: inline-block; 
    margin-top: 1.5rem; 
    padding: 0.5rem 1.5rem; 
    background: rgba(56, 189, 248, 0.1); 
    color: #38bdf8; 
    text-decoration: none; 
    border-radius: 999px; 
    font-weight: bold; 
    transition: all 0.2s ease;
    border: 1px solid #38bdf8;
    align-self: flex-start;
  }
  .cta-button:hover { 
    background: #38bdf8; 
    color: #0f172a; 
  }
</style>

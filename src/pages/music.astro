---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Modern Chinese Classical Music - Grandevity Limited" lang="en">
  <main style="max-width: 800px; margin: 0 auto; padding: 2rem 1rem; min-height: 70vh;">
    <header style="text-align: center; margin-bottom: 3rem;">
      <h1 style="font-size: 2.5rem; margin-bottom: 1rem; color: #1e293b;">A Contemporary Renaissance</h1>
      <p style="color: #64748b; font-size: 1.15rem; line-height: 1.7; max-width: 700px; margin: 0 auto;">
        Bridging the gap between historical masterpieces and modern aesthetics. We focus on composing modern pop arrangements (Mandopop, Indie, Chillhop) for ancient traditional Chinese poetry. Join us for a musical journey perfect for driving, relaxing, and healing the modern soul.
      </p>
    </header>

    <div style="margin-bottom: 3rem;">
      <h2 style="font-size: 1.5rem; color: #0f172a; margin-bottom: 1rem; border-bottom: 2px solid #e2e8f0; padding-bottom: 0.5rem;">Featured Music Video</h2>
      <div style="border-radius: 12px; overflow: hidden; aspect-ratio: 16/9; background: #000; box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1);">
        <iframe 
          width="100%" 
          height="100%" 
          src="https://youtu.be/lkCpRb9tXEY" 
          title="Grandevity Original Music" 
          frameborder="0" 
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
      <div style="text-align: right; margin-top: 0.5rem;">
        <a href="https://www.youtube.com/channel/UC8Uch86j4-V7pm7RorRI3GQ" target="_blank" rel="noopener noreferrer" style="color: #2563eb; text-decoration: none; font-weight: 500; font-size: 0.95rem;">
          Explore more on YouTube ➔
        </a>
      </div>
    </div>

    <div style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 12px; padding: 2rem;">
      <h2 style="font-size: 1.25rem; color: #0f172a; margin-top: 0; margin-bottom: 0.75rem;">Business & Copyright</h2>
      <p style="color: #475569; font-size: 0.95rem; line-height: 1.6; margin-bottom: 1rem;">
        All original music, arrangements, and visual contents are operated and copyrighted by <strong>Grandevity Limited</strong>. We welcome non-exclusive BGM licensing for indie games, films, vlogs, and commercials.
      </p>
      <p style="margin: 0; font-size: 0.95rem;">
        <strong style="color: #1e293b;">Business Inquiries:</strong> 
        <a href="mailto:contact@grandevity.co.nz" style="color: #2563eb; text-decoration: none;">contact@grandevity.co.nz</a>
      </p>
    </div>
  </main>
</Layout>
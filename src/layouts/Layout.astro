---
// 1. 接收 title 和 lang（语言）作为参数，默认语言设为 'en'
const { title, lang = 'en', description, schema, image, type = 'website' } = Astro.props;

// 2. 生成当前页面的 Canonical URL (解决 Google 重复页面报错)
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteUrl = new URL('/', Astro.site).toString();
const pageTitle = title.includes('Grandevity') ? title : `${title} | Grandevity Limited`;
const pageDescription = description ?? (
  lang === 'en'
    ? 'Grandevity Limited is a New Zealand digital studio and music project creating original interactive experiences, HTML5 games, and modern Mandopop reimaginings of classical Chinese poetry.'
    : lang === 'zh-Hans'
      ? 'Grandevity Limited 是新西兰注册的数字工作室与音乐企划，打造原创互动体验、HTML5 游戏，以及以古典诗词为灵感的现代华语音乐。'
      : 'Grandevity Limited 是紐西蘭註冊的數位工作室與音樂企劃，打造原創互動體驗、HTML5 遊戲，以及以古典詩詞為靈感的現代華語音樂。'
);
const socialImage = new URL(image ?? '/logo.png', Astro.site);

// 3. 清理路径并生成三语言 SEO 链接 (Hreflang)
let rawPath = Astro.url.pathname;
if (rawPath.startsWith('/zh-hans/')) {
  rawPath = rawPath.replace('/zh-hans/', '/');
} else if (rawPath === '/zh-hans') {
  rawPath = '/';
} else if (rawPath.startsWith('/zh/')) {
  rawPath = rawPath.replace('/zh/', '/');
} else if (rawPath === '/zh') {
  rawPath = '/';
}

const enUrl = new URL(rawPath, Astro.site);
const zhHantPath = rawPath === '/' ? '/zh/' : `/zh${rawPath}`;
const zhHansPath = rawPath === '/' ? '/zh-hans/' : `/zh-hans${rawPath}`;
const zhHantUrl = new URL(zhHantPath, Astro.site);
const zhHansUrl = new URL(zhHansPath, Astro.site);

// 4. 三语言导航路径
const langPrefix = lang === 'en' ? '' : lang === 'zh-Hans' ? '/zh-hans' : '/zh';
const homePath = lang === 'en' ? '/' : `${langPrefix}/`;
const gamesPath = lang === 'en' ? '/#games' : `${langPrefix}/#games`;
const musicPath = lang === 'en' ? '/music' : `${langPrefix}/music`;
const blogPath = lang === 'en' ? '/blog' : `${langPrefix}/blog`;
const aboutPath = lang === 'en' ? '/about' : `${langPrefix}/about`;
const privacyPath = lang === 'en' ? '/privacy-policy' : `${langPrefix}/privacy-policy`;
const termsPath = lang === 'en' ? '/terms-of-service' : `${langPrefix}/terms-of-service`;

const labels = {
  home: lang === 'en' ? 'Home' : lang === 'zh-Hans' ? '首页' : '首頁',
  games: lang === 'en' ? 'Games' : lang === 'zh-Hans' ? '游戏' : '遊戲',
  music: lang === 'en' ? 'Music' : lang === 'zh-Hans' ? '音乐' : '音樂',
  insights: lang === 'en' ? 'Insights' : lang === 'zh-Hans' ? '洞察' : '洞察',
  tagline: lang === 'en' ? 'Engineering Digital Worlds.' : lang === 'zh-Hans' ? '构建数字世界。' : '構建數位世界。',
  philosophy: lang === 'en'
    ? '"The majestic serenity arising from immense strength and established wisdom."'
    : '「松椿萬丈，狐兔不驚。」',
  contact: lang === 'en' ? 'Get in Touch' : lang === 'zh-Hans' ? '联系我们' : '聯絡我們',
  office: lang === 'en' ? 'Registered Office' : lang === 'zh-Hans' ? '注册地址' : '註冊辦公室',
  incorporated: lang === 'en' ? 'Proudly incorporated in New Zealand.' : lang === 'zh-Hans' ? '于新西兰注册成立。' : '於紐西蘭註冊成立。',
  about: lang === 'en' ? 'About Us' : lang === 'zh-Hans' ? '关于我们' : '關於我們',
  privacy: lang === 'en' ? 'Privacy Policy' : lang === 'zh-Hans' ? '隐私政策' : '隱私權政策',
  terms: lang === 'en' ? 'Terms of Service' : lang === 'zh-Hans' ? '服务条款' : '服務條款',
};

// 5. 注入 JSON-LD 结构化数据：定义公司、品牌工作室与音乐项目的关系
const schemaData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://grandevity.co.nz/#organization",
      "name": "Grandevity Limited",
      "alternateName": ["Grandevity", "Grandevity Studio", "Grandevity Music"],
      "legalName": "Grandevity Limited",
      "url": siteUrl,
      "logo": "https://grandevity.co.nz/logo.png",
      "description": "Grandevity Limited is a New Zealand digital studio creating original interactive experiences, HTML5 games, and modern music releases.",
      "identifier": {
        "@type": "PropertyValue",
        "propertyID": "NZBN",
        "value": "9429053472120"
      },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "9 Huron Street",
        "addressLocality": "Takapuna",
        "addressRegion": "Auckland",
        "postalCode": "0622",
        "addressCountry": "NZ"
      },
      "sameAs": [
        "https://www.youtube.com/@GrandevityMusic",
        "https://www.youtube.com/channel/UC8Uch86j4-V7pm7RorRI3GQ"
      ],
      "brand": {
        "@type": "Brand",
        "name": "Grandevity Studio",
        "alternateName": "Grandevity Music"
      }
    },
    {
      "@type": "WebSite",
      "@id": "https://grandevity.co.nz/#website",
      "name": "Grandevity",
      "alternateName": "Grandevity Limited",
      "url": siteUrl,
      "publisher": {
        "@id": "https://grandevity.co.nz/#organization"
      },
      "inLanguage": ["en", "zh-Hant", "zh-Hans"]
    },
    {
      "@type": "MusicGroup",
      "@id": "https://grandevity.co.nz/#music",
      "name": "Grandevity",
      "alternateName": ["Grandevity Music", "Grandevity Studio"],
      "url": "https://grandevity.co.nz/music/",
      "description": "Grandevity Music is the classical literature reimagined music series and modern Mandopop R&B creative project of Grandevity Studio.",
      "sameAs": [
        "https://www.youtube.com/@GrandevityMusic",
        "https://www.youtube.com/channel/UC8Uch86j4-V7pm7RorRI3GQ"
      ]
    }
  ]
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:site_name" content="Grandevity Limited" />
    <meta property="og:locale" content={lang === 'zh-Hans' ? 'zh_CN' : lang === 'zh-Hant' || lang === 'zh' ? 'zh_TW' : 'en_NZ'} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={socialImage} />
    
    <link rel="canonical" href={canonicalURL} />

    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="zh-Hant" href={zhHantUrl} />
    <link rel="alternate" hreflang="zh-Hans" href={zhHansUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}

    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6297520668105698" crossorigin="anonymous"></script>
  </head>
  <body>
    <nav>
      <a href={homePath} class="logo-link">
        <img src="/logo.png" alt="Grandevity Logo" class="nav-logo" />
      </a>
      <div class="links">
        <a href={homePath}>{labels.home}</a>
        <a href={gamesPath}>{labels.games}</a>
        <a href={musicPath}>{labels.music}</a>
        <a href={blogPath}>{labels.insights}</a>
  
        <div class="nav-divider"></div>
        <a href={enUrl.pathname} class:list={['lang-switch', { active: lang === 'en' }]}>EN</a>
        <a href={zhHantUrl.pathname} class:list={['lang-switch', { active: lang === 'zh-Hant' || lang === 'zh' }]}>繁</a>
        <a href={zhHansUrl.pathname} class:list={['lang-switch', { active: lang === 'zh-Hans' }]}>简</a>
      </div>
    </nav>
    
    <slot />
    
    <footer>
      <div class="footer-content">
        <div class="footer-brand">
          <span class="logo-text">Grandevity</span>
          <p class="tagline">{labels.tagline}</p>
          <div class="philosophy">
            {labels.philosophy}
          </div>
        </div>
        
        <div class="footer-contact">
          <h4>{labels.contact}</h4>
          <div class="contact-links">
            <a href="mailto:info@grandevity.co.nz">info@grandevity.co.nz</a>
            <a href="tel:+642040064937">+64 20 4006 4937</a>
          </div>
        </div>

        <div class="footer-location">
          <h4>{labels.office}</h4>
          <p>9 Huron Street<br />
             Takapuna<br />
             Auckland 0622<br />
             New Zealand</p>
        </div>
      </div>
      
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} Grandevity Limited. {labels.incorporated}</p>
        <p class="nzbn-text">NZBN: 9429053472120</p>
      
        <div style="margin-top: 1rem; display: flex; justify-content: center; align-items: center; gap: 1rem;">
          <a href={aboutPath} style="color: #64748b; text-decoration: none; font-size: 0.9rem;">
            {labels.about}
          </a>
          <span style="color: #475569; font-size: 0.9rem;">|</span>
          <a href={privacyPath} style="color: #64748b; text-decoration: none; font-size: 0.9rem;">
            {labels.privacy}
          </a>
          <span style="color: #475569; font-size: 0.9rem;">|</span>
          <a href={termsPath} style="color: #64748b; text-decoration: none; font-size: 0.9rem;">
            {labels.terms}
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  /* 基础 CSS 保持不变 */
  :root {
    --bg-dark: #0f172a;
    --text-light: #f8fafc;
    --accent-glow: #38bdf8;
    --card-bg: #1e293b;
  }
  
  html {
    font-family: system-ui, -apple-system, sans-serif;
    background: var(--bg-dark);
    color: var(--text-light);
    scroll-behavior: smooth;
  }
  
  body {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 5%;
    background: rgba(15, 23, 42, 0.9);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .logo-link { display: flex; align-items: center; }
  .nav-logo {
    height: 40px; width: auto;
    filter: brightness(0) invert(1);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  .nav-logo:hover { opacity: 0.8; transform: scale(1.02); }

  .links { display: flex; align-items: center; }
  .links a {
    color: var(--text-light); text-decoration: none;
    margin-left: 2rem;
    font-size: 0.9rem; transition: color 0.2s;
  }
  .links a:hover { color: var(--accent-glow); }

  /* 语言切换按钮样式 */
  .nav-divider {
    width: 1px; height: 16px; background: rgba(255,255,255,0.2);
    margin-left: 2rem;
  }
  .lang-switch {
    background: rgba(255,255,255,0.1);
    padding: 0.3rem 0.6rem;
    border-radius: 4px;
    font-weight: 600;
    letter-spacing: 1px;
  }
  .lang-switch:hover, .lang-switch.active { background: rgba(56, 189, 248, 0.2); color: #38bdf8; }

  /* 底部 Footer 样式 */
  footer { margin-top: auto; padding: 4rem 5% 1.5rem; border-top: 1px solid rgba(255,255,255,0.05); background: rgba(0, 0, 0, 0.2); }

  /* 核心修改区：缩小最大宽度，强制整体居中 */
  .footer-content { 
    display: flex; 
    flex-wrap: wrap; 
    justify-content: space-between;
    max-width: 900px; 
    margin: 0 auto 3rem; 
    gap: 2rem;
  }

  .footer-brand { 
    flex: 1 1 350px; 
    max-width: 400px;
  }

  .footer-contact, .footer-location { 
    flex: 0 0 auto; 
  }

  .footer-brand .logo-text { font-weight: 800; font-size: 1.2rem; letter-spacing: 1px; text-transform: uppercase; }
  .footer-brand .tagline { color: #f8fafc; font-size: 0.95rem; margin-top: 0.5rem; margin-bottom: 1.5rem; }
  .footer-brand .philosophy { font-style: italic; color: #94a3b8; font-size: 0.85rem; line-height: 1.5; padding-left: 1rem; border-left: 2px solid rgba(56, 189, 248, 0.5); }
  .footer-contact h4, .footer-location h4 { margin: 0 0 1rem 0; font-size: 0.9rem; color: #f8fafc; text-transform: uppercase; letter-spacing: 1px; }
  .contact-links { display: flex; flex-direction: column; gap: 0.75rem; }
  .contact-links a { color: #94a3b8; text-decoration: none; font-size: 0.9rem; transition: color 0.2s; }
  .contact-links a:hover { color: #38bdf8; }
  .footer-location p { color: #94a3b8; font-size: 0.9rem; line-height: 1.6; margin: 0; }
  .footer-bottom { max-width: 1200px; margin: 0 auto; padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.05); display: flex; flex-direction: column; align-items: center; text-align: center; }
  .footer-bottom p { margin: 0 0 0.5rem 0; font-size: 0.8rem; color: #64748b; }
  .nzbn-text {letter-spacing: 0.5px; }

  /* 手机端适配 */
  @media (max-width: 768px) { 
    .footer-content { 
      flex-direction: column; 
      gap: 3rem; 
      max-width: 100%; 
    } 
  }
</style>

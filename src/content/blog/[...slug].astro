---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// 这个函数告诉 Astro 去找所有英文的 Markdown 文件，并为它们生成专属网址
export async function getStaticPaths() {
  const blogEntries = await getCollection('blog', ({ id }) => {
    return id.startsWith('en/');
  });
  
  return blogEntries.map(entry => ({
    params: { slug: entry.slug.replace('en/', '') }, 
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render(); // 把 Markdown 转换成 HTML
---

<Layout title={`${entry.data.title} | Grandevity`} lang="en">
  <main class="article-container">
    <article>
      <header class="article-header">
        <h1>{entry.data.title}</h1>
        <div class="meta">
          <span>By {entry.data.author}</span> • 
          <time>{entry.data.date.toLocaleDateString('en-US')}</time>
        </div>
      </header>
      
      <div class="markdown-content">
        <!-- 这里就是自动渲染的 Markdown 正文 -->
        <Content /> 
      </div>
    </article>
  </main>
</Layout>

<style is:global>
  /* 针对 Markdown 正文的专业排版样式 */
  .article-container {
    max-width: 800px;
    margin: 0 auto;
    padding: 4rem 5%;
    min-height: 60vh;
  }
  
  .article-header {
    margin-bottom: 3rem;
    text-align: center;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding-bottom: 2rem;
  }
  
  .article-header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: #f8fafc;
  }
  
  .meta {
    color: #94a3b8;
    font-size: 0.9rem;
  }
  
  /* Markdown 内容的具体样式 */
  .markdown-content {
    color: #cbd5e1;
    line-height: 1.8;
    font-size: 1.1rem;
  }
  
  .markdown-content h1, .markdown-content h2, .markdown-content h3 {
    color: #f8fafc;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  
  .markdown-content a {
    color: #38bdf8;
    text-decoration: none;
  }
  
  .markdown-content a:hover {
    text-decoration: underline;
  }
</style>
---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 抓取中文博客，并过滤掉未来发布的文章
const allPosts = await getCollection('blog', ({ id }) => id.startsWith('zh/'));
const today = new Date();
const visiblePosts = allPosts.filter(post => new Date(post.data.date) <= today);

// 提取音乐板块文章 (路径包含 'music/')
const musicPosts = visiblePosts
  .filter(post => post.id.includes('music/'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);

// 提取洞见板块文章 (排除音乐)
const latestInsights = visiblePosts
  .filter(post => !post.id.includes('music/'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);
---

<Layout title="Grandevity | 互动工作室与数字解决方案" lang="zh">
  <main>
    <header class="hero">
      <h1>构建 <span class="text-gradient">数字世界</span></h1>
      <p>Grandevity 是一家多领域混合型工作室，致力于打造原创互动体验，并为现代企业提供顶级的数字架构、财务合规与战略咨询服务。</p>
    </header>

    <section id="music" class="section-container">
      <h2>古典新编音乐</h2>
      <p class="section-subtitle">用现代视听语言，重构跨越千年的古典诗词与精神坐标。</p>
      
      <div class="card-grid">
        {musicPosts.length === 0 ? (
          <div class="card" style="grid-column: 1 / -1; text-align: center;">
            <div class="card-content">
              <p>全新视听企划正在制作中，敬请期待。</p>
            </div>
          </div>
        ) : (
          musicPosts.map((post) => (
            <a href={`/zh/blog/${post.id.replace('zh/', '')}`} class="card" style="text-decoration: none; color: inherit; display: block;">
              <div class="card-content">
                <h3>{post.data.title}</h3>
                <span class="badge" style="background: rgba(168, 85, 247, 0.1); color: #c084fc;">🎵 最新单曲释出</span>
                <p>{post.data.description}</p>
                <div class="cta-button">了解企划详情 ➔</div>
              </div>
            </a>
          ))
        )}
      </div>

      <div style="text-align: center; margin-top: 3rem;">
        <a href="/zh/music" style="color: #94a3b8; text-decoration: none; border-bottom: 1px solid #475569; padding-bottom: 2px; transition: color 0.2s;">
          进入视听主页探索所有 MV ➔
        </a>
      </div>
    </section>

    <section id="games" class="section-container">
      <h2>原创游戏</h2>
      
      <div class="card-grid">
        <div class="card game-card">
          <a href="/play/kiwi-defenders/" style="text-decoration: none;">
            <div class="game-image-placeholder" style="background-image: url('/images/games/kiwi-defenders/landscape_cover_campaign_map.webp'); background-size: cover; background-position: center;">
              <span style="background: rgba(0,0,0,0.7); padding: 0.5rem 1rem; border-radius: 4px; color: #38bdf8; font-weight: bold; font-size: 1.2rem; backdrop-filter: blur(4px);">▶ 点击试玩 Demo</span>
            </div>
          </a>
          <div class="card-content">
            <h3>Kiwi Defenders</h3>
            <span class="badge" style="background: rgba(34, 197, 94, 0.1); color: #22c55e;">试玩版上线</span>
            <p>一款极具策略性的 HTML5 塔防游戏。在独特的几维鸟主题战役地图上指挥你的防线。直接在浏览器中体验纯净的无 SDK 独立版本。</p>
            <a href="/play/kiwi-defenders/" class="cta-button">立即游玩 ➔</a>
          </div>
        </div>

        <div class="card game-card">
          <div class="game-image-placeholder" style="background: #0f172a; background-size: cover; background-position: center;">
            <span style="color: #475569; font-weight: 800; font-size: 1.5rem; letter-spacing: 4px;">[ 机密档案 ]</span>
          </div>
          <div class="card-content">
            <h3>代号：Pebble <span style="font-size: 0.8rem; font-weight: normal; color: #94a3b8;">(开发代号)</span></h3>
            <span class="badge" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b;">研发中</span>
            <p>我们的下一款原创作品目前正处于早期原型设计和核心工程阶段。探索全新的互动机制，更多细节即将公布。</p>
          </div>
        </div>
      </div>
    </section>

    <section id="insights" class="section-container">
      <h2>最新洞见</h2>
      <p class="section-subtitle">深入探讨历史、系统设计与数字架构。</p>
      
      <div class="card-grid">
        {latestInsights.map((post) => (
          <a href={`/zh/blog/${post.id.replace('zh/', '')}`} class="card" style="text-decoration: none; color: inherit; display: block;">
            <div class="card-content">
              <h3>{post.data.title}</h3>
              <span class="badge" style="background: rgba(56, 189, 248, 0.1); color: #38bdf8;">{post.data.category || '洞察'}</span>
              <p>{post.data.description}</p>
              <div class="cta-button">阅读文章 ➔</div>
            </div>
          </a>
        ))}
      </div>


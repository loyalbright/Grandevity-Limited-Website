---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Play Kiwi Defenders | Grandevity" lang="en">
  <main class="player-container">
    <header class="game-header">
      <h1>Kiwi Defenders</h1>
      <p>Defend the islands in this strategic HTML5 tower defense experience.</p>
    </header>

    <!-- 游戏 iframe 容器 -->
    <div class="iframe-wrapper">
      <iframe 
        id="game-frame"
        src="/games/kiwi-defenders/" 
        title="Kiwi Defenders Game" 
        frameborder="0" 
        scrolling="no" 
        allowfullscreen>
      </iframe>
    </div>

    <!-- 游戏控制栏 -->
    <div class="game-controls">
      <button id="fullscreen-btn" class="cta-button">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align: middle; margin-right: 8px;"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"></path></svg>
        Enter Fullscreen
      </button>
    </div>
  </main>
</Layout>

<style>
  .player-container { 
    padding: 2rem 5% 4rem; 
    max-width: 1200px; 
    margin: 0 auto; 
    text-align: center; 
  }
  
  .game-header { margin-bottom: 2rem; }
  .game-header h1 { font-size: 2.5rem; margin-bottom: 0.5rem; color: #f8fafc; }
  .game-header p { color: #94a3b8; }
  
  /* --- 核心魔法：完美 16:9 响应式容器 --- */
  .iframe-wrapper {
    position: relative;
    width: 100%;
    max-width: 1024px; /* 防止在带鱼屏上拉得过大 */
    margin: 0 auto;
    aspect-ratio: 16 / 9; /* 原生维持 16:9 比例 */
    background: #0f172a;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(255,255,255,0.1);
  }
  
  .iframe-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
    /* 确保 iframe 内置背景透明，完美融入你的网站 */
    background-color: transparent; 
  }

  /* 按钮样式 */
  .game-controls { margin-top: 2rem; }
  .cta-button { 
    display: inline-flex;
    align-items: center;
    background: rgba(56, 189, 248, 0.1); 
    color: #38bdf8; 
    border: 1px solid #38bdf8; 
    padding: 0.75rem 2rem; 
    border-radius: 999px; 
    font-weight: bold; 
    font-size: 1rem;
    cursor: pointer; 
    transition: all 0.2s ease;
  }
  .cta-button:hover { 
    background: #38bdf8; 
    color: #0f172a; 
    transform: translateY(-2px);
  }
</style>

<style is:global>
  /* --- 1. 解除导航栏锁死 --- */
  /* 如果你的 Layout 中使用了 nav 或 header 作为主导航，将其还原为跟随滚动的状态 */
  nav, .navbar, header:not(.game-header) {
    position: static !important; 
  }

  /* --- 2. 手机横屏：终极沉浸模式 --- */
  /* 当检测到设备是横屏，且高度较小（通常是手机）时触发 */
  @media (max-height: 600px) and (orientation: landscape) {
    /* 直接隐藏主导航栏、游戏标题和底部的全屏按钮，把屏幕 100% 交给游戏 */
    nav, .navbar, footer, .game-header, .game-controls {
      display: none !important;
    }
    
    /* 抹平容器的所有内边距 */
    .player-container {
      padding: 0 !important;
      max-width: 100% !important;
    }
    
    /* 让 iframe 容器取消圆角，彻底铺满屏幕 */
    .iframe-wrapper {
      border-radius: 0 !important;
      border: none !important;
      height: 100vh !important;
      aspect-ratio: auto !important; /* 取消固定的 16:9，让游戏引擎自己去适配手机宽高比 */
    }
  }
</style>

<script>
  // 前端全屏逻辑
  const btn = document.getElementById('fullscreen-btn');
  const iframe = document.getElementById('game-frame');
  
  btn.addEventListener('click', () => {
    if (iframe.requestFullscreen) {
      iframe.requestFullscreen();
    } else if (iframe.webkitRequestFullscreen) { /* Safari 支持 */
      iframe.webkitRequestFullscreen();
    } else if (iframe.msRequestFullscreen) { /* IE11 支持 */
      iframe.msRequestFullscreen();
    }
  });
</script>
---
// 注意这里要多退一层目录才能找到 layouts
import Layout from '../../layouts/Layout.astro';
---

<Layout title="原创音乐与原声带 - Grandevity Limited" lang="zh">
  <main style="max-width: 800px; margin: 0 auto; padding: 2rem 1rem; min-height: 70vh;">
    <h1 style="font-size: 2.5rem; margin-bottom: 0.5rem; color: #1e293b;">原创音乐</h1>
    <p style="color: #64748b; margin-bottom: 3rem; font-size: 1.1rem;">
      探索为我们的游戏世界精心打造的原创原声带与沉浸式音频体验。
    </p>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 2rem;">
      
      <div style="border: 1px solid #e2e8f0; border-radius: 12px; padding: 1.5rem; background: #f8fafc;">
        <h2 style="margin-top: 0; color: #0f172a;">Kiwi Defenders 原声带</h2>
        <p style="color: #475569; font-size: 0.95rem;">完整的原创游戏配乐，包含动感的战斗主旋律与氛围感十足的探索曲目。</p>
        <div style="margin-top: 1rem; padding: 1rem; background: #e2e8f0; border-radius: 8px; text-align: center; color: #64748b;">
          [ 音频播放器 / 嵌入代码将放置于此 ]
        </div>
      </div>

      <div style="border: 1px solid #e2e8f0; border-radius: 12px; padding: 1.5rem; background: #f8fafc;">
        <h2 style="margin-top: 0; color: #0f172a;">代号：Pebble (开发中)</h2>
        <p style="color: #475569; font-size: 0.95rem;">为我们即将推出的全新互动体验所制作的早期音频原型与氛围草图。</p>
        <div style="margin-top: 1rem; padding: 1rem; background: #e2e8f0; border-radius: 8px; text-align: center; color: #64748b;">
          [ 音频播放器 / 嵌入代码将放置于此 ]
        </div>
      </div>

    </div>
  </main>
</Layout>
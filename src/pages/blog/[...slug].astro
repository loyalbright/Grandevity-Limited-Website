---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog', ({ id }) => {
    return id.startsWith('en/');
  });
  
  return blogEntries.map(entry => ({
    params: { slug: entry.id.replace('en/', '') }, 
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry); 
---

<Layout title={`${entry.data.title} | Grandevity`} lang="en">
  <main class="article-container">
    <article>
      <header class="article-header">
        <h1>{entry.data.title}</h1>
        
        {/* 如果有副标题，就在这里渲染出来 */}
        {entry.data.description && <p class="article-description">{entry.data.description}</p>}
        
        <div class="meta">
          <span>By {entry.data.author}</span> • 
          <time>{entry.data.date.toLocaleDateString('en-US')}</time>
        </div>

        {/* 如果有标签，就在这里循环渲染出来 */}
        {entry.data.tags && (
          <div class="tags-container">
            {entry.data.tags.map((tag) => (
              <span class="tag-badge">#{tag}</span>
            ))}
          </div>
        )}
      </header>
      
      <div class="markdown-content">
        <Content /> 
      </div>
    </article>
  </main>
</Layout>

<style is:global>
  .article-container { max-width: 800px; margin: 0 auto; padding: 4rem 5%; min-height: 60vh; }
  .article-header { margin-bottom: 3rem; text-align: center; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 2rem; }
  .article-header h1 { font-size: 2.5rem; margin-bottom: 1rem; color: #f8fafc; }
  .article-description { font-size: 1.25rem; color: #94a3b8; margin-top: -0.5rem; margin-bottom: 1.5rem; line-height: 1.6; }
  .tags-container { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.5rem; margin-top: 1.5rem; }
  .tag-badge { background: rgba(56, 189, 248, 0.1); color: #38bdf8; padding: 0.25rem 0.75rem; border-radius: 999px; font-size: 0.85rem; font-weight: 600; }
  .meta { color: #94a3b8; font-size: 0.9rem; }
  .markdown-content { color: #cbd5e1; line-height: 1.8; font-size: 1.1rem; }
  .markdown-content h1, .markdown-content h2, .markdown-content h3 { color: #f8fafc; margin-top: 2.5rem; margin-bottom: 1rem; }
  .markdown-content a { color: #38bdf8; text-decoration: none; }
  .markdown-content a:hover { text-decoration: underline; }
  /* --- 控制文章内的图片排版 --- */
  .markdown-content img {
    max-width: 100%;       /* 绝对不超过文章容器的宽度 */
    height: auto;          /* 自动按比例缩放高度，防止变形 */
    display: block;        /* 独立占一行 */
    margin: 2.5rem auto;   /* 上下留出优雅的空白，左右居中 */
    border-radius: 8px;    /* 加上微微的圆角，更有高级感 */
    border: 1px solid rgba(255,255,255,0.05); /* 加一层极淡的边框融入暗黑主题 */
  }
</style>
---
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <nav>
      <a href="/" class="logo-link">
        <img src="/logo.png" alt="Grandevity Logo" class="nav-logo" />
      </a>
      <div class="links">
        <a href="#games">Games</a>
        <a href="#services">Services</a>
      </div>
    </nav>
    <slot />
    <footer>
      <div class="footer-content">
        <div class="footer-brand">
          <span class="logo-text">Grandevity</span>
          <p class="tagline">Engineering Digital Worlds.</p>
          <div class="philosophy">
            "The majestic serenity arising from immense strength and established wisdom."
          </div>
        </div>
        
        <div class="footer-contact">
          <h4>Get in Touch</h4>
          <div class="contact-links">
            <a href="mailto:info@grandevity.co.nz">info@grandevity.co.nz</a>
            <a href="tel:+64000000000">+64 20 4006 4937</a>
          </div>
        </div>

        <div class="footer-location">
          <h4>Registered Office</h4>
          <p>9 Huron Street<br />
             Takapuna<br />
             Auckland 0622<br />
             New Zealand</p>
        </div>
      </div>
      
      <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} Grandevity Limited. Proudly incorporated in New Zealand.</p>
        <p class="nzbn-text">NZBN: 9429053472120</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg-dark: #0f172a;
    --text-light: #f8fafc;
    --accent-glow: #38bdf8;
    --card-bg: #1e293b;
  }
  
  html {
    font-family: system-ui, -apple-system, sans-serif;
    background: var(--bg-dark);
    color: var(--text-light);
    scroll-behavior: smooth;
  }
  
  body {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 5%;
    background: rgba(15, 23, 42, 0.9);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
    z-index: 100;
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .logo-link {
    display: flex;
    align-items: center;
  }

  .nav-logo {
    height: 40px;
    width: auto;
    filter: brightness(0) invert(1); /* Change/remove if using a transparent logo */
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .nav-logo:hover {
    opacity: 0.8;
    transform: scale(1.02);
  }

  .links a {
    color: var(--text-light);
    text-decoration: none;
    margin-left: 2rem;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .links a:hover {
    color: var(--accent-glow);
  }

  /* --- FOOTER STYLES --- */
  footer {
    margin-top: auto;
    padding: 4rem 5% 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.05);
    background: rgba(0, 0, 0, 0.2);
  }

  .footer-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 3rem;
    max-width: 1200px;
    margin: 0 auto 3rem;
  }

  .footer-brand .logo-text {
    font-weight: 800;
    font-size: 1.2rem;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .footer-brand .tagline {
    color: #f8fafc;
    font-size: 0.95rem;
    margin-top: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .footer-brand .philosophy {
    font-style: italic;
    color: #94a3b8;
    font-size: 0.85rem;
    line-height: 1.5;
    padding-left: 1rem;
    border-left: 2px solid rgba(56, 189, 248, 0.5); /* Subtle blue glow border */
  }

  .footer-contact h4, .footer-location h4 {
    margin: 0 0 1rem 0;
    font-size: 0.9rem;
    color: #f8fafc;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .contact-links a {
    color: #94a3b8;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .contact-links a:hover {
    color: var(--accent-glow);
  }

  .footer-location p {
    color: #94a3b8;
    font-size: 0.9rem;
    line-height: 1.6;
    margin: 0;
  }

  .footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.05);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .footer-bottom p {
    margin: 0 0 0.5rem 0;
    font-size: 0.8rem;
    color: #64748b;
  }

  .nzbn-text {
    font-family: monospace;
    letter-spacing: 0.5px;
  }

  /* Responsive tweak for smaller screens */
  @media (max-width: 768px) {
    .footer-content {
      gap: 2rem;
    }
  }
</style>